{
  "id": "capsule",
  "display_name": "Capsule / Line Segment",
  "mathematical_definition": "Distance from point p to a line segment from a to b, minus radius: length(p - a - clamp(dot(p-a, b-a)/dot(b-a, b-a), 0, 1) * (b-a)) - radius.",
  "dimension": 3,
  "parameters": {
    "point_a": {
      "type": "vec3",
      "default": [
        0.0,
        -1.0,
        0.0
      ]
    },
    "point_b": {
      "type": "vec3",
      "default": [
        0.0,
        1.0,
        0.0
      ]
    },
    "radius": {
      "type": "float",
      "min": 0.01,
      "max": 10.0,
      "default": 0.3
    }
  },
