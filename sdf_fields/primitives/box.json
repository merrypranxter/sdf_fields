{
  "id": "box",
  "display_name": "Box / Rounded Box",
  "mathematical_definition": "Distance from point p to an axis-aligned box: length(max(abs(p) - halfSize, 0.0)) + min(max(abs(p).x - halfSize.x, max(abs(p).y - halfSize.y, abs(p).z - halfSize.z)), 0.0). Optional rounding subtracts a radius.",
  "dimension": 3,
  "parameters": {
    "half_size": {
      "type": "vec3",
      "min": [
        0.01,
        0.01,
        0.01
      ],
      "max": [
        100.0,
        100.0,
        100.0
      ],
      "default": [
        1.0,
        1.0,
        1.0
      ]
    },
    "rounding": {
      "type": "float",
      "min": 0.0,
      "max": 1.0,
      "default": 0.0
    }
  },
  "visual_keywords": [
    "cubic",
    "architectural",
    "hard",
    "angular",
    "monolith",
    "block"
  ],
  "good_for": [
    "architecture",
    "rooms",
    "monoliths",
    "subtraction targets",
    "frames"
  ],
  "art_failure_modes": [
    "Sharp edges alias badly without anti-aliasing or soft shadows.",
    "Axis-aligned boxes look generic \u2014 rotate or round for interest."
  ],
